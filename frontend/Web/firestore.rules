rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions for role validation
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'admin';
    }
    
    function isProfessor() {
      return isAuthenticated() && getUserData().role == 'professor';
    }
    
    function isStudent() {
      return isAuthenticated() && getUserData().role == 'student';
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Users collection - strict role-based access
    match /users/{userId} {
      allow read: if true; // Open for backend operations
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }
    
    // Professors collection - admin only write
    match /professors/{professorId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Students collection - admin only write
    match /students/{studentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Courses collection - public read, admin/professor write, students can enroll
    match /courses/{courseId} {
      allow read: if true; // Public read for enrollment checks
      allow create: if isAdmin();
      allow update: if isAdmin() || 
                      (isProfessor() && resource.data.professorId == request.auth.uid) ||
                      (isStudent() && 
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['enrolledStudents']) &&
                       request.resource.data.enrolledStudents.hasAll(resource.data.enrolledStudents));
      allow delete: if isAdmin();
    }
    
    // Sessions collection - professor creates, students read
    match /sessions/{sessionId} {
      allow read: if true; // Temporarily open for backend testing
      allow create: if isProfessor();
      allow update: if isProfessor() && resource.data.professorId == request.auth.uid;
      allow delete: if isProfessor() && resource.data.professorId == request.auth.uid;
    }
    
    // Attendance collection - strict validation
    match /attendance/{attendanceId} {
      allow read: if true; // Open for backend operations
      allow create: if isStudent() && request.resource.data.studentId == request.auth.uid;
      allow update: if isProfessor() || isAdmin();
      allow delete: if isAdmin();
    }
    
    // Attendance appeals - students create, professors update
    match /attendanceAppeals/{appealId} {
      allow read: if isAuthenticated();
      allow create: if isStudent() && request.resource.data.studentId == request.auth.uid;
      allow update: if isProfessor() && resource.data.professorId == request.auth.uid;
      allow delete: if isAdmin();
    }
    
    // Notifications collection
    match /notifications/{notificationId} {
      allow read: if true; // Backend needs unauthenticated read for cooldown checks
      allow create: if true; // Backend needs unauthenticated write
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
    }
    
    // Enrollments collection
    match /enrollments/{enrollmentId} {
      allow read: if true; // Open for backend operations
      allow create: if isAdmin() || isProfessor() || 
                      (isStudent() && request.resource.data.studentId == request.auth.uid);
      allow update: if isAdmin() || isProfessor();
      allow delete: if isAdmin();
    }
    
    // Security Alerts collection - admin only
    match /securityAlerts/{alertId} {
      allow read: if isAdmin() || isProfessor();
      allow create: if isAuthenticated(); // Cloud Functions can create
      allow update: if isAdmin() || isProfessor();
      allow delete: if isAdmin();
    }
    
    // Chat collections for AI assistant
    match /conversations/{conversationId} {
      allow read, write: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
    }
    
    match /messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.sender == request.auth.uid;
      allow delete: if isAdmin();
    }
  }
}